---
import BlogList from "~/layouts/BlogList.astro";
import {
  LOCALES,
  getPostsByCluster,
  CLUSTER_LABELS,
  type Locale,
} from "~/lib/i18n";

export async function getStaticPaths() {
  const CLUSTERS = ["comparison", "pricing", "local-seo", "advisor-program", "recipe"];
  const paths = [];

  for (const lang of LOCALES) {
    for (const cluster of CLUSTERS) {
      paths.push({
        params: { lang, cluster },
      });
    }
  }

  return paths;
}

const { lang, cluster } = Astro.params;
const locale = lang as Locale;

const posts = await getPostsByCluster(cluster, locale);

const clusterDescriptions: Record<string, Record<Locale, string>> = {
  comparison: {
    en: "Honest comparisons between the Thermomix and other kitchen appliances. Pros, cons, and which one fits your kitchen.",
    es: "Comparaciones honestas entre la Thermomix y otros electrodomésticos de cocina. Pros, contras y cuál encaja en tu cocina.",
    pt: "Comparações honestas entre o Thermomix e outros eletrodomésticos. Prós, contras e qual cabe na sua cozinha.",
  },
  pricing: {
    en: "Thermomix pricing in the USA, financing options, payment plans, and promotional offers.",
    es: "Precios de la Thermomix en EE.UU., opciones de financiamiento, planes de pago y ofertas promocionales.",
    pt: "Preços do Thermomix nos EUA, opções de financiamento, planos de pagamento e ofertas promocionais.",
  },
  "local-seo": {
    en: "Thermomix demos and advisors near you in Texas, Houston, The Woodlands, and surrounding areas.",
    es: "Demostraciones y asesoras de Thermomix cerca de ti en Texas, Houston, The Woodlands y áreas cercanas.",
    pt: "Demonstrações e consultoras Thermomix perto de você em Texas, Houston, The Woodlands e regiões próximas.",
  },
  "advisor-program": {
    en: "Everything about the Thermomix Advisor program: how it works, income potential, and how to start.",
    es: "Todo sobre el programa Thermomix Advisor: cómo funciona, potencial de ingresos y cómo empezar.",
    pt: "Tudo sobre o programa Thermomix Advisor: como funciona, potencial de renda e como começar.",
  },
  recipe: {
    en: "Recipes designed for the Thermomix. Step-by-step guides, prep tips, and time-saving techniques.",
    es: "Recetas pensadas para la Thermomix. Guías paso a paso, consejos de preparación y técnicas para ahorrar tiempo.",
    pt: "Receitas pensadas para o Thermomix. Guias passo a passo, dicas de preparo e técnicas para economizar tempo.",
  },
};

const SITE = "https://getsmartcooking.com";
---

<BlogList
  posts={posts}
  locale={locale}
  title={CLUSTER_LABELS[cluster][locale]}
  description={clusterDescriptions[cluster][locale]}
  canonical={`${SITE}/blog/${locale}/cluster/${cluster}/`}
  cluster={cluster}
/>

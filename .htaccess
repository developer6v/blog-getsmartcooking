# ====================================================================
# Get Smart Cooking, .htaccess for Apache/cPanel
# Compatible with Cloudflare proxy mode
# ====================================================================

# ============ FORCE HTTPS ============
# When Cloudflare proxies the site, the origin receives HTTP.
# The X-Forwarded-Proto header tells us the user's actual protocol.
# This rule avoids redirect loops when Cloudflare is in Flexible SSL mode.
RewriteEngine On

RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]


# ============ REMOVE .html FROM URLs ============
# Step 1, if visitor lands on /en/privacy.html, 301 redirect to /en/privacy
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# Step 2, when visitor requests /en/privacy, internally serve /en/privacy.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]


# ============ 404 FALLBACK ============
# If a URL does not exist, send the visitor to the root.
# The root index.html detects browser language and redirects to /en/, /es/, or /pt/.
ErrorDocument 404 /


# ============ DEFAULT FILES ============
DirectoryIndex index.html


# ============ COMPRESSION ============
# Gzip text-based files. Cuts page weight by ~70% for HTML/CSS/JS.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/x-font-ttf
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>


# ============ BROWSER CACHE ============
# Tell browsers how long to cache static assets.
# HTML pages: 1 hour (so updates propagate quickly)
# CSS/JS: 1 week
# Images and videos: 1 month
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 hour"
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType text/javascript "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpg "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType video/mp4 "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>


# ============ SECURITY HEADERS ============
<IfModule mod_headers.c>
  # Prevent browsers from MIME-sniffing file types
  Header set X-Content-Type-Options "nosniff"

  # Disallow embedding in iframes (prevents clickjacking)
  Header set X-Frame-Options "SAMEORIGIN"

  # Limit referrer info sent to other sites
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Tell browsers to always use HTTPS for 1 year
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Allow Meta Pixel, GA4, and Google Fonts to load
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://connect.facebook.net https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://www.facebook.com; frame-src https://www.facebook.com;"
</IfModule>


# ============ BLOCK BAD BOTS AND HIDDEN FILES ============
# Prevent direct access to .htaccess, .git, and similar hidden files.
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# Block common bad bots that scrape and waste bandwidth.
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_USER_AGENT} (AhrefsBot|MJ12bot|SemrushBot|DotBot) [NC]
  RewriteRule ^ - [F,L]
</IfModule>

---
import { getCollection, type CollectionEntry } from "astro:content";

export interface Props {
  currentSlug: string;
  cluster: string;
  locale: "en" | "es" | "pt";
  limit?: number;
}

const { currentSlug, cluster, locale, limit = 3 } = Astro.props;

const collectionName = `blog_${locale}` as "blog_en" | "blog_es" | "blog_pt";
const allPosts = await getCollection(
  collectionName,
  ({ data }: { data: any }) => !data.draft && data.slug !== currentSlug
);

// Prioriza posts do mesmo cluster
const sameCluster = allPosts.filter((p: any) => p.data.cluster === cluster);
const otherPosts = allPosts.filter((p: any) => p.data.cluster !== cluster);

const related = [...sameCluster, ...otherPosts]
  .sort(
    (a: any, b: any) =>
      new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
  )
  .slice(0, limit);

const labels = {
  en: { title: "You might also like" },
  es: { title: "También te puede gustar" },
  pt: { title: "Você também pode gostar" },
};
---

{
  related.length > 0 && (
    <section class="related-posts">
      <h2 class="related-title">{labels[locale].title}</h2>
      <div class="related-grid">
        {related.map((post: any) => (
          <a href={`/${locale}/blog/${post.data.slug}/`} class="related-card">
            <img
              src={post.data.heroImage}
              alt={post.data.heroImageAlt}
              loading="lazy"
              class="related-image"
            />
            <div class="related-content">
              <h3 class="related-card-title">{post.data.title}</h3>
              <p class="related-card-description">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )
}

<style>
  .related-posts {
    margin: 4rem 0 2rem;
    padding-top: 3rem;
    border-top: 1px solid #e5e7eb;
  }

  .related-title {
    font-size: 1.875rem;
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .related-card {
    text-decoration: none;
    color: inherit;
    border-radius: 0.75rem;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    background: white;
    border: 1px solid #e5e7eb;
  }

  .related-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
  }

  .related-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .related-content {
    padding: 1.25rem;
  }

  .related-card-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    line-height: 1.3;
  }

  .related-card-description {
    font-size: 0.9375rem;
    color: #6b7280;
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

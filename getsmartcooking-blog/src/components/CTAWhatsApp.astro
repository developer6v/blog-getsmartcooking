---
export interface Props {
  variant?: "inline" | "banner" | "final";
  headline?: string;
  subtext?: string;
  message?: string;
  locale?: "en" | "es" | "pt";
}

const {
  variant = "inline",
  headline,
  subtext,
  message,
  locale = "en",
} = Astro.props;

const WHATSAPP_NUMBER = "18328045758";

const defaultMessages = {
  en: "Hi Natascha, I saw your page and want to know more about Thermomix.",
  es: "Hola Natascha, vi tu página y quiero saber más sobre Thermomix.",
  pt: "Oi Natascha, vi sua página e quero saber mais sobre o Thermomix.",
};

const defaultHeadlines = {
  inline: {
    en: "See the Thermomix in action",
    es: "Mira la Thermomix en acción",
    pt: "Veja a Thermomix em ação",
  },
  banner: {
    en: "One conversation. That's all it takes.",
    es: "Una conversación. Eso es todo.",
    pt: "Uma conversa. É só isso.",
  },
  final: {
    en: "Ready to see it work? Chat with Natascha.",
    es: "¿Lista para verla funcionar? Chatea con Natascha.",
    pt: "Pronta para ver funcionando? Fale com a Natascha.",
  },
};

const defaultSubtexts = {
  en: "No forms. No sales pressure. Real conversation, real answers.",
  es: "Sin formularios. Sin presión de venta. Conversación real, respuestas reales.",
  pt: "Sem formulários. Sem pressão de venda. Conversa real, respostas reais.",
};

const buttonLabels = {
  en: "Chat on WhatsApp",
  es: "Chatear por WhatsApp",
  pt: "Falar no WhatsApp",
};

const finalMessage = message || defaultMessages[locale];
const finalHeadline = headline || defaultHeadlines[variant][locale];
const finalSubtext = subtext || defaultSubtexts[locale];

const whatsappUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(finalMessage)}`;
---

{
  variant === "inline" && (
    <div class="cta-inline">
      <p class="cta-inline-text">{finalHeadline}</p>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="cta-inline-link"
        data-cta="whatsapp-inline"
      >
        {buttonLabels[locale]} →
      </a>
    </div>
  )
}

{
  variant === "banner" && (
    <div class="cta-banner">
      <div class="cta-banner-content">
        <h3 class="cta-banner-headline">{finalHeadline}</h3>
        <p class="cta-banner-subtext">{finalSubtext}</p>
      </div>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="cta-banner-button"
        data-cta="whatsapp-banner"
      >
        {buttonLabels[locale]}
      </a>
    </div>
  )
}

{
  variant === "final" && (
    <div class="cta-final">
      <h2 class="cta-final-headline">{finalHeadline}</h2>
      <p class="cta-final-subtext">{finalSubtext}</p>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="cta-final-button"
        data-cta="whatsapp-final"
      >
        {buttonLabels[locale]}
      </a>
    </div>
  )
}

<style>
  .cta-inline {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    background: #f0fdf4;
    border-left: 4px solid #25d366;
    border-radius: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    .cta-inline {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .cta-inline-text {
    margin: 0;
    font-weight: 500;
    color: #064e3b;
  }

  .cta-inline-link {
    color: #25d366;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }

  .cta-inline-link:hover {
    text-decoration: underline;
  }

  .cta-banner {
    margin: 3rem 0;
    padding: 2rem;
    background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);
    border-radius: 1rem;
    color: white;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .cta-banner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .cta-banner-headline {
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
    font-weight: 700;
  }

  .cta-banner-subtext {
    margin: 0;
    opacity: 0.95;
  }

  .cta-banner-button {
    display: inline-block;
    padding: 0.875rem 2rem;
    background: white;
    color: #128c7e;
    font-weight: 700;
    text-decoration: none;
    border-radius: 0.5rem;
    white-space: nowrap;
    transition: transform 0.15s ease;
  }

  .cta-banner-button:hover {
    transform: translateY(-2px);
  }

  .cta-final {
    margin: 4rem 0 2rem;
    padding: 3rem 2rem;
    text-align: center;
    background: #064e3b;
    border-radius: 1rem;
    color: white;
  }

  .cta-final-headline {
    margin: 0 0 1rem 0;
    font-size: 2rem;
    font-weight: 700;
  }

  .cta-final-subtext {
    margin: 0 0 2rem 0;
    opacity: 0.9;
    font-size: 1.125rem;
  }

  .cta-final-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: #25d366;
    color: white;
    font-weight: 700;
    font-size: 1.125rem;
    text-decoration: none;
    border-radius: 0.5rem;
    transition: transform 0.15s ease;
  }

  .cta-final-button:hover {
    transform: translateY(-2px);
  }
</style>

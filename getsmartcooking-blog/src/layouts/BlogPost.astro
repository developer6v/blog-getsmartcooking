---
import SEOHead from "~/components/seo/SEOHead.astro";
import ArticleSchema from "~/components/seo/ArticleSchema.astro";
import FAQSchema from "~/components/seo/FAQSchema.astro";
import RecipeSchema from "~/components/seo/RecipeSchema.astro";
import BreadcrumbSchema from "~/components/seo/BreadcrumbSchema.astro";
import CTAWhatsApp from "~/components/CTAWhatsApp.astro";
import FAQ from "~/components/FAQ.astro";
import RelatedPosts from "~/components/RelatedPosts.astro";
import { formatDate } from "~/lib/utils";
import { getAlternateLanguages, type Locale } from "~/lib/i18n";

export interface Props {
  frontmatter: {
    title: string;
    description: string;
    slug: string;
    publishDate: Date;
    updatedDate?: Date;
    author: string;
    heroImage: string;
    heroImageAlt: string;
    cluster: string;
    tags?: string[];
    translationKey: string;
    faq?: Array<{ question: string; answer: string }>;
    recipeData?: any;
  };
  locale: Locale;
}

const { frontmatter, locale } = Astro.props;

const SITE = "https://getsmartcooking.com";
const canonical = `${SITE}/${locale}/blog/${frontmatter.slug}/`;

const alternateLanguages = await getAlternateLanguages(
  frontmatter.translationKey,
  locale
);

const breadcrumbLabels = {
  en: { home: "Home", blog: "Blog" },
  es: { home: "Inicio", blog: "Blog" },
  pt: { home: "Início", blog: "Blog" },
};

const labels = breadcrumbLabels[locale];

const breadcrumbItems = [
  { name: labels.home, url: `/${locale}/` },
  { name: labels.blog, url: `/${locale}/blog/` },
  { name: frontmatter.title, url: canonical },
];

const isRecipe = frontmatter.cluster === "recipe" && frontmatter.recipeData;
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <SEOHead
      title={`${frontmatter.title} | Get Smart Cooking`}
      description={frontmatter.description}
      canonical={canonical}
      image={frontmatter.heroImage}
      imageAlt={frontmatter.heroImageAlt}
      type="article"
      publishDate={frontmatter.publishDate}
      updatedDate={frontmatter.updatedDate}
      author={frontmatter.author}
      locale={locale}
      alternateLanguages={alternateLanguages}
    />
    <ArticleSchema
      title={frontmatter.title}
      description={frontmatter.description}
      url={canonical}
      image={frontmatter.heroImage}
      imageAlt={frontmatter.heroImageAlt}
      publishDate={frontmatter.publishDate}
      updatedDate={frontmatter.updatedDate}
      author={frontmatter.author}
      locale={locale}
    />
    <BreadcrumbSchema items={breadcrumbItems} />
    {frontmatter.faq && <FAQSchema faq={frontmatter.faq} />}
    {
      isRecipe && (
        <RecipeSchema
          title={frontmatter.title}
          description={frontmatter.description}
          image={frontmatter.heroImage}
          author={frontmatter.author}
          publishDate={frontmatter.publishDate}
          recipeData={frontmatter.recipeData}
        />
      )
    }
  </head>
  <body>
    <!-- Aqui você importa o Header existente do site -->
    <!-- <Header locale={locale} /> -->

    <article class="blog-post">
      <header class="post-header">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href={`/${locale}/`}>{labels.home}</a>
          <span> / </span>
          <a href={`/${locale}/blog/`}>{labels.blog}</a>
          <span> / </span>
          <span aria-current="page">{frontmatter.title}</span>
        </nav>

        <h1 class="post-title">{frontmatter.title}</h1>

        <div class="post-meta">
          <span class="post-author">{frontmatter.author}</span>
          <span>·</span>
          <time datetime={frontmatter.publishDate.toISOString()}>
            {formatDate(frontmatter.publishDate, locale)}
          </time>
          {
            frontmatter.updatedDate && (
              <>
                <span>·</span>
                <span class="updated-label">
                  {locale === "en" && "Updated"}
                  {locale === "es" && "Actualizado"}
                  {locale === "pt" && "Atualizado"}{" "}
                  {formatDate(frontmatter.updatedDate, locale)}
                </span>
              </>
            )
          }
        </div>

        <img
          src={frontmatter.heroImage}
          alt={frontmatter.heroImageAlt}
          class="post-hero"
          loading="eager"
          fetchpriority="high"
        />
      </header>

      <div class="post-content">
        <slot />
      </div>

      {frontmatter.faq && <FAQ faq={frontmatter.faq} locale={locale} />}

      <CTAWhatsApp variant="final" locale={locale} />

      <RelatedPosts
        currentSlug={frontmatter.slug}
        cluster={frontmatter.cluster}
        locale={locale}
      />
    </article>

    <!-- Aqui você importa o Footer existente do site -->
    <!-- <Footer locale={locale} /> -->

    <style>
      .blog-post {
        max-width: 760px;
        margin: 0 auto;
        padding: 2rem 1.25rem;
      }

      .post-header {
        margin-bottom: 2rem;
      }

      .breadcrumb {
        font-size: 0.875rem;
        color: #6b7280;
        margin-bottom: 1.5rem;
      }

      .breadcrumb a {
        color: #6b7280;
        text-decoration: none;
      }

      .breadcrumb a:hover {
        text-decoration: underline;
      }

      .post-title {
        font-size: 2.5rem;
        font-weight: 800;
        line-height: 1.15;
        margin: 0 0 1.5rem 0;
      }

      @media (min-width: 768px) {
        .post-title {
          font-size: 3rem;
        }
      }

      .post-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        font-size: 0.9375rem;
        color: #6b7280;
        margin-bottom: 2rem;
      }

      .post-author {
        font-weight: 600;
        color: #111827;
      }

      .post-hero {
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        border-radius: 0.75rem;
      }

      .post-content {
        font-size: 1.125rem;
        line-height: 1.7;
        color: #1f2937;
      }

      .post-content :global(h2) {
        font-size: 1.875rem;
        font-weight: 700;
        margin: 2.5rem 0 1rem 0;
        line-height: 1.3;
      }

      .post-content :global(h3) {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 2rem 0 0.75rem 0;
      }

      .post-content :global(p) {
        margin: 1.25rem 0;
      }

      .post-content :global(a) {
        color: #128c7e;
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .post-content :global(ul),
      .post-content :global(ol) {
        margin: 1.25rem 0;
        padding-left: 1.5rem;
      }

      .post-content :global(li) {
        margin: 0.5rem 0;
      }

      .post-content :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 0.5rem;
        margin: 2rem 0;
      }

      .post-content :global(blockquote) {
        margin: 2rem 0;
        padding: 1rem 1.5rem;
        border-left: 4px solid #25d366;
        background: #f0fdf4;
        font-style: italic;
      }
    </style>
  </body>
</html>
